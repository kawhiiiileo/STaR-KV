# Copy to starkv_local_paths.env and edit (gitignored).
# All values are optional; export only what you need.

# STARKV_MODEL_DIR=/path/to/models
# STARKV_DATASETS_DIR=/path/to/datasets
# STARKV_RESULTS_DIR=/path/to/results
# PYTHON_BIN=/path/to/python

# Optional conda auto-activate (requires CONDA_BASE or conda on PATH):
# STARKV_AUTO_CONDA=1
# STARKV_CONDA_ENV=starkv
